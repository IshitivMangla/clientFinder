# Email sender settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM="Your Name" <you@example.com>

# IMAP settings for reply tracking
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=you@example.com
IMAP_PASS=your-imap-password
IMAP_TLS=true

# Optional Google Places API settings to discover businesses automatically
GOOGLE_PLACES_API_KEY=
SEARCH_QUERY=restaurant hotel
SEARCH_LOCATION=40.7128,-74.0060
SEARCH_RADIUS=5000

# Enable actual email sending. Set to true when ready.
SEND_EMAIL=false
DRY_RUN=true

# Optional OpenAI API key for more natural reply generation
OPENAI_API_KEY=

# Optional NVIDIA API Settings (alternative to OpenAI)
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
